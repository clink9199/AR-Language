## Fibonacci in AR Language

func fibonacci(n) {
    if n <= 1 {
        return n
    }
    let a = 0
    let b = 1
    let i = 2
    loop i <= n {
        let temp = a + b
        a = b
        b = temp
        i = i + 1
    }
    return b
}

output("Fibonacci sequence (first 10):")
let count = 0
loop count < 10 {
    let result = fibonacci(count)
    output("  fib(" + count + ") = " + result)
    count = count + 1
}
